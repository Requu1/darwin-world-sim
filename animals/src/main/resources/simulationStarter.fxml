<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            minHeight="550.0" minWidth="850.0"
            fx:controller="agh.ics.oop.presenter.SimulationPresenter"
>
    <center>
        <StackPane>
            <VBox alignment="CENTER" spacing="10">
                <Label text="All animals will be living here!" textAlignment="CENTER"/>
                <TextField fx:id="inputTextField" maxWidth="250"/>
                <Button text="Confirm args" onAction="#onSimulationStartClicked"/>
            </VBox>
        </StackPane>
    </center>


</BorderPane>