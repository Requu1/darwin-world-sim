<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            minHeight="550.0" minWidth="850.0"
            fx:controller="agh.ics.oop.presenter.SimulationStarterPresenter"
>
    <center>
        <HBox alignment="CENTER" spacing="100">

            <VBox alignment="CENTER_LEFT" spacing="15">


                <VBox spacing="5">
                    <Label text="Map size (Width / Height)" style="-fx-font-weight: bold;"/>
                    <HBox spacing="10">
                        <TextField fx:id="mapWidthInput" text="15" prefWidth="95"/>
                        <TextField fx:id="mapHeightInput" text="15" prefWidth="95"/>
                    </HBox>
                </VBox>


                <VBox spacing="5">
                    <Label text="Starting plants count" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="startingPlantsCountInput" text="10" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Energy restored after eating a plant" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="plantEnergyRestoreInput" text="25" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Plants growing each day" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="dailyGrowingPlantsInput" text="5" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Starting animal count" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="startingAnimalCountInput" text="5" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Minimal world temperature" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="minTemperatureInput" text="-20" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Warm distance" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="warmDistanceInput" text="5" maxWidth="200"/>
                </VBox>
            </VBox>

            <VBox alignment="CENTER_LEFT" spacing="15">
                <VBox spacing="5">
                    <Label text="Season duration" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="seasonDurationInput" text="50" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Default animal energy" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="defaultEnergyInput" text="50" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Animal daily energy loss" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="energyLossInput" text="5" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Energy for animal to be able to reproduce" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="canReproduceEnergyForAnimalInput" text="50" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Energy needed to reproduce" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="reproductionEnergyInput" text="20" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Genome length" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="genomeLengthInput" text="10" maxWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Mutations (Min / Max)" style="-fx-font-weight: bold;"/>
                    <HBox spacing="10">
                        <TextField fx:id="minMutationsInput" text="0" prefWidth="95"/>
                        <TextField fx:id="maxMutationsInput" text="3" prefWidth="95"/>
                    </HBox>
                </VBox>
            </VBox>

        </HBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" style="-fx-padding: 30 0 0 0;">
            <Button text="Start Simulation"
                    onAction="#onSimulationStartClicked"
                    prefWidth="250"
                    prefHeight="50"
                    style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </VBox>
    </bottom>


</BorderPane>